{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "System.Net.Http.HttpClient": "Warning"
        }
    },
    "Sources": {
        "Global": {
            "FailureThreshold": 2,
            "CooldownSeconds": 120
        },
        "USDA": {
            "Enabled": true,
            "TimeoutMs": 2200
        },
        "GTINSearch": {
            "Enabled": true,
            "TimeoutMs": 4500
        },
        "GTINSearchBarcode": {
            "Enabled": true,
            "TimeoutMs": 1800
        },
        "OpenFoodFacts": {
            "Enabled": true,
            "TimeoutMs": 1500
        },
        "OpenFoodFactsBarcode": {
            "Enabled": true,
            "TimeoutMs": 1200
        },
        "OpenFoodFactsSearch": {
            "Enabled": false,
            "TimeoutMs": 1500
        }
    },
    "AllowedHosts": "*"
}
